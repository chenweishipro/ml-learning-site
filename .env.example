# ML 学习站 环境变量样例
# 复制为 .env 并填入实际值

# ===== Database =====
# SQLite (开发/单机部署)
DATABASE_URL="file:./dev.db"

# ===== Auth =====
# 用于签发/验证 JWT 的密钥,生产环境必须改成随机长字符串
# 生成: openssl rand -base64 48
AUTH_SECRET="dev-secret-please-replace-in-production-min-32chars-required-xxxxx"
# JWT 过期时间(秒),默认 30 天
AUTH_SESSION_TTL="2592000"
# 重置密码 token 过期时间(秒),默认 1 小时
AUTH_RESET_TTL="3600"

# ===== Email (SMTP) =====
# 用于发送重置密码邮件
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="ML 学习站 <noreply@example.com>"

# ===== Site URL =====
# 用于邮件中的重置链接、回调地址
NEXT_PUBLIC_SITE_URL="http://122.51.221.63:7892"
