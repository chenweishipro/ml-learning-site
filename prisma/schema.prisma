// Prisma schema for ML 学习站
// SQLite for zero-deps local DB; upgradeable to Postgres later

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  // 角色: "user" (默认) | "admin" (可编辑内容) | "superadmin" (可设管理员)
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  resetTokens  PasswordResetToken[]
  progress     ChapterProgress[]
  contentEdits ContentEditLog[]
  revisions    ContentRevision[]
  proposals    ContentProposal[] @relation("ProposalAuthor")
  reviews      ContentProposal[] @relation("ProposalReviewer")
  notifications Notification[]
  studySessions StudySession[]
  studyPlans   StudyPlan[]
  certificates Certificate[]
  quizWrongs  QuizWrong[]
  codingSubs  CodingSubmission[]
  comments     Comment[]
  commentLikes CommentLike[]
  notes        Note[]
  questions    Question[] @relation("QuestionAuthor")
  answers      Answer[] @relation("AnswerAuthor")
  answerVotes  AnswerVote[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique  // SHA-256 of the actual token; raw token only in email
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ChapterProgress {
  id         String   @id @default(cuid())
  userId     String
  courseSlug String
  chapterSlug String
  completed  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseSlug, chapterSlug])
  @@index([userId])
}

// 课程级覆盖 (管理员编辑的课程元数据)
model CourseOverride {
  id          String   @id @default(cuid())
  courseSlug  String   @unique
  // 以下字段都可空: null = 跟仓库文件一致, 字符串 = 覆盖
  title       String?
  description String?
  level       String?  // "beginner" | "intermediate" | "advanced"
  duration    String?
  tags        String?  // JSON 数组字符串
  // 完整 MDX body 章节列表(整本 course.md 的内容, 整段替换)
  body        String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  edits       ContentEditLog[]
}

// 章节级覆盖 (管理员编辑的章节 MDX body)
model ChapterOverride {
  id           String   @id @default(cuid())
  courseSlug   String
  chapterSlug  String
  // 完整章节 MDX 内容(整段替换 chapter.mdx)
  body         String
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  edits        ContentEditLog[]

  @@unique([courseSlug, chapterSlug])
  @@index([courseSlug])
}

// 编辑日志(审计)
model ContentEditLog {
  id            String   @id @default(cuid())
  scope         String   // "course" | "chapter"
  courseSlug    String
  chapterSlug   String?  // null when scope=course
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 关联的 override id(可选)
  courseRefId   String?
  chapterRefId  String?
  action        String   // "save" | "delete"
  // 摘要(前 200 字符,便于审计时快速浏览)
  summary       String?
  createdAt     DateTime @default(now())

  courseRef     CourseOverride?  @relation(fields: [courseRefId], references: [id], onDelete: SetNull)
  chapterRef    ChapterOverride? @relation(fields: [chapterRefId], references: [id], onDelete: SetNull)

  @@index([scope, courseSlug, chapterSlug])
  @@index([userId])
  @@index([createdAt])
}

// 学习会话 (每次进入章节页 / 标记完成时记录, 用于学习时长统计)
model StudySession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseSlug  String
  chapterSlug String
  // 学习秒数
  durationSec Int      @default(0)
  // 当天日期 (yyyy-mm-dd), 用于每日聚合
  studyDate   String
  // 完成的次数 (该 session 内标记完成)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, studyDate])
  @@index([userId, courseSlug, chapterSlug])
}

// 学习计划 (用户自己设的目标, 例: 7 天内学完课程 X)
model StudyPlan {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseSlug  String
  // 目标完成日期
  targetDate  DateTime?
  // 每日目标章节数
  dailyTarget Int      @default(1)
  // 是否激活
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, active])
}

// 学完证书 (一门课完整学完后生成的证书)
model Certificate {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseSlug  String
  // 颁发时间
  issuedAt    DateTime @default(now())
  // 完成度 (0-100, 99.9% 也算完成)
  finalScore  Float    @default(100)
  // 证书唯一编号
  serialNo    String   @unique

  @@unique([userId, courseSlug])
  @@index([serialNo])
}

// 学习笔记 (用户对某段文本的笔记 + 高亮)
model Note {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 关联章节 (笔记依附于章节)
  courseSlug  String
  chapterSlug String
  // 高亮的文本 (从 MDX 抓出来的一段)
  highlightedText String
  // 笔记内容 (用户自己写的备注)
  content     String
  // 可选的颜色标签 (yellow/red/green/blue)
  color       String   @default("yellow")
  // 状态: "active" | "deleted"
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, courseSlug, chapterSlug])
  @@index([userId, createdAt])
}

// Q&A 问题
model Question {
  id          String   @id @default(cuid())
  // 标题
  title       String
  // 详细描述 (Markdown)
  body        String
  // 关联课程 (可选)
  courseSlug  String?
  // 关联章节 (可选)
  chapterSlug String?
  // 标签 (逗号分隔, 简单处理)
  tags        String   @default("")
  // 状态: "open" (有答案) | "answered" (有被采纳的) | "closed" (关闭)
  status      String   @default("open")
  // 答案数
  answerCount Int      @default(0)
  // 浏览数
  viewCount   Int      @default(0)
  // 点赞数
  voteCount   Int      @default(0)
  // 提问者
  authorId    String
  author      User     @relation("QuestionAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  // 关联答案
  answers     Answer[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
  @@index([courseSlug, chapterSlug])
  @@index([authorId])
  @@index([voteCount])
  // ✨ 复合索引, 加快列表与详情查询
  @@index([courseSlug, status, voteCount])
  @@index([courseSlug, chapterSlug, status, createdAt])
  @@index([tags])
  @@index([status, answerCount])
}

// Q&A 答案
model Answer {
  id          String   @id @default(cuid())
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  body        String
  // 答题人
  authorId    String
  author      User     @relation("AnswerAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  // 是否被采纳
  accepted    Boolean  @default(false)
  // 点赞数
  voteCount   Int      @default(0)
  // 状态: "published" | "deleted"
  status      String   @default("published")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  votes       AnswerVote[]

  @@index([questionId, voteCount])
  @@index([questionId, accepted])
  @@index([authorId])
}

model AnswerVote {
  id        String   @id @default(cuid())
  answerId  String
  answer    Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([answerId, userId])
  @@index([userId])
}

// 章节内评论 (社区互动)
model Comment {
  id          String   @id @default(cuid())
  scope       String   // "course" | "chapter"
  courseSlug  String
  chapterSlug String?  // null when scope=course
  // 回复关系: 顶级评论 parentId=null, 回复 parentId=父评论id
  parentId    String?
  parent      Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentReplies")

  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  body        String   // 评论内容 (markdown 友好, 但不做复杂渲染, 保留纯文本)
  // 状态: "published" | "hidden" | "deleted"
  status      String   @default("published")
  // 点赞数 (冗余字段, 加速排序)
  likeCount   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 点赞记录 (谁给哪条评论点过赞, 防止重复)
  likes       CommentLike[]

  @@index([scope, courseSlug, chapterSlug, createdAt])
  @@index([authorId])
  @@index([parentId])
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([commentId, userId])
  @@index([userId])
}

// 内容修订快照(可回滚)
// 每次保存前先在 override 表的当前值生成一份快照
// body 存储完整内容 (课程: JSON 化的元信息+body, 章节: MDX 字符串)
model ContentRevision {
  id          String   @id @default(cuid())
  scope       String   // "course" | "chapter"
  courseSlug  String
  chapterSlug String?  // null when scope=course
  // 完整快照内容 (课程: JSON.stringify({title,description,level,duration,tags,body}), 章节: MDX 字符串)
  body        String
  // 可选: 保存原因/备注,例如 "初始保存" / "回滚到 revision:abc"
  summary     String?
  // 快照来源: "save" (保存前自动生成) | "rollback" (手动回滚写入) | "initial" (首次创建 override)
  source      String   @default("save")
  // 如果是回滚产生的快照, 这里记录被回滚的目标版本
  restoredFrom String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([scope, courseSlug, chapterSlug, createdAt])
  @@index([userId])
  @@index([createdAt])
}


// 内容修改提案 (PR 模式)
// 任何登录用户都可以提交, 管理员在 /admin/proposals 审核
model ContentProposal {
  id            String   @id @default(cuid())
  scope         String   // "course" | "chapter"
  courseSlug    String
  chapterSlug   String?  // null when scope=course

  // 作者
  authorId      String
  author        User     @relation("ProposalAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  // 提案信息
  title         String   // 用户填的简短标题
  description   String   // 用户填的修改说明

  // 内容
  proposedBody  String   // 新内容 (course: JSON 化的元信息; chapter: MDX 字符串)
  baseSnapshot  String   // 提案基于的"基准"内容, 用于冲突检测

  // 状态: "pending" | "approved" | "merged" | "rejected" | "withdrawn"
  status        String   @default("pending")

  // 审核
  reviewerId    String?
  reviewer      User?    @relation("ProposalReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewNote    String?
  reviewedAt    DateTime?

  // 合并结果
  mergedAt      DateTime?
  mergedRevisionId String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
  @@index([authorId])
  @@index([scope, courseSlug, chapterSlug])
}

// 站内信 (用户通知)
model Notification {
  id          String   @id @default(cuid())
  recipientId String
  recipient   User     @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  // 类型: "proposal_merged" | "proposal_rejected" | "proposal_approved" | "system"
  type        String
  title       String
  body        String
  // 站内跳转链接
  link        String?
  // 附加元信息 (JSON), 例如 { proposalId, courseSlug, chapterSlug }
  meta        String?

  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([recipientId, readAt, createdAt])
  @@index([createdAt])
}

model QuizWrong {
  id            String   @id @default(cuid())
  userId        String
  courseSlug    String
  chapterSlug   String
  questionIndex Int
  userAnswer    Int
  correctAnswer Int
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseSlug, chapterSlug, questionIndex])
  @@index([userId, resolved])
  @@index([userId, updatedAt])
}

model AiSummary {
  id           String   @id @default(cuid())
  courseSlug   String
  chapterSlug  String
  summary      String
  content      String   // 章节内容 hash, 内容变化时重新生成
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([courseSlug, chapterSlug])
  @@index([updatedAt])
}

model CodingSubmission {
  id           String   @id @default(cuid())
  userId       String
  courseSlug   String
  chapterSlug  String
  challengeId  String
  code         String
  passed       Boolean
  passedTests  Int
  totalTests   Int
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, challengeId])
  @@index([userId, passed])
  @@index([userId, createdAt])
}
